# Copy these into Cloudflare Pages -> Settings -> Environment variables (Production).
# Never commit real values or paste them into chat -- paste directly into Cloudflare's UI.

# --- Supabase (required for everything) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Cron auth (you invent this string yourself, any random value) ---
CRON_SECRET=

# --- Deployed dashboard URL (set after first deploy, used for webhook callbacks + Slack links) ---
APP_URL=

# --- Cleanlist (phone auto-enrich + email on-demand) ---
CLEANLIST_API_KEY=

# --- Slack SDR notifications ---
NOTIFY_CHANNEL=slack
NOTIFY_WEBHOOK_URL=

# --- SalesBlink (sequencing + sending) ---
SALESBLINK_API_KEY=

# --- Close CRM (SDR status + pipeline sync) ---
CLOSE_API_KEY=

# --- Cost governor: hard ceiling on Cleanlist spend, $0.10/credit ---
WEEKLY_SPEND_CAP_USD=5
MONTHLY_SPEND_CAP_USD=20

# --- Optional: only needed if you want live LLM scoring/sequence-writing instead of
# the deterministic rubric scorer + manual Claude-MCP sessions for rule teaching ---
# ANTHROPIC_API_KEY=
